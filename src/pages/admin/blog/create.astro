---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Tambah Artikel">
  <div class="mb-8">
    <h1 class="text-3xl font-bold">Tambah Artikel</h1>

    <p class="mt-2 text-slate-500">Tambahkan artikel baru.</p>
  </div>

  <form class="grid grid-cols-3 gap-8">
    <!-- KIRI -->

    <div class="col-span-2 space-y-6">
      <div class="rounded-2xl border bg-white p-6">
        <label class="mb-2 block font-medium"> Judul Artikel </label>

        <input type="text" class="w-full rounded-xl border border-slate-300 px-4 py-3" />
      </div>

      <div class="rounded-2xl border bg-white p-6">
        <label class="mb-2 block font-medium"> Ringkasan </label>

        <textarea rows="5" class="w-full rounded-xl border border-slate-300 px-4 py-3"></textarea>
      </div>

      <div class="rounded-2xl border bg-white p-6">
        <label class="mb-2 block font-medium"> Isi Artikel </label>

        <textarea rows="15" class="w-full rounded-xl border border-slate-300 px-4 py-3"></textarea>
      </div>
    </div>

    <!-- KANAN -->

    <div class="space-y-6">
      <div class="rounded-2xl border bg-white p-6">
        <label class="mb-2 block font-medium"> Thumbnail </label>

        <input type="file" class="w-full rounded-xl border border-slate-300 p-3" />
      </div>

      <div class="rounded-2xl border bg-white p-6">
        <label class="mb-2 block font-medium"> Kategori </label>

        <select class="w-full rounded-xl border border-slate-300 px-4 py-3">
          <option>Informasi</option>

          <option>Berita</option>

          <option>Pengumuman</option>
        </select>
      </div>

      <div class="rounded-2xl border bg-white p-6">
        <label class="mb-2 block font-medium"> Status </label>

        <select class="w-full rounded-xl border border-slate-300 px-4 py-3">
          <option>Draft</option>

          <option>Publish</option>
        </select>
      </div>

      <button class="w-full rounded-xl bg-blue-600 py-3 text-white"> Simpan Artikel </button>
    </div>
  </form>
</AdminLayout>
