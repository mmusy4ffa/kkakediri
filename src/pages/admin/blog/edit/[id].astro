---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { supabaseServer } from '../../../../lib/supabaseServer';

export const prerender = false;

export async function getStaticPaths() {
  const { data: blogs } = await supabaseServer.from('blogs').select('id');

  return (
    blogs?.map((item) => ({
      params: { id: String(item.id) },
    })) || []
  );
}

const { id } = Astro.params;

const { data: item } = await supabaseServer.from('blogs').select('*').eq('id', Number(id)).single();
---

<AdminLayout title="Edit Blog">
  <div class="mb-8">
    <h1 class="text-3xl font-bold">Edit Blog</h1>
  </div>

  <form id="edit-form" class="grid gap-8 lg:grid-cols-3">
    <div class="space-y-6 lg:col-span-2">
      <div class="rounded-2xl border bg-white p-6">
        <label class="block mb-2">Title</label>
        <input
          id="title"
          name="title"
          value={item?.title || ''}
          class="w-full rounded-xl border px-4 py-3"
        />
      </div>

      <div class="rounded-2xl border bg-white p-6">
        <label class="block mb-2">Slug (URL unik)</label>
        <input
          id="slug"
          name="slug"
          value={item?.slug || ''}
          class="w-full rounded-xl border px-4 py-3"
        />
      </div>

      <div class="rounded-2xl border bg-white p-6">
        <label class="block mb-2">Konten</label>
        <textarea id="content" name="content" rows="8" class="w-full rounded-xl border px-4 py-3"
          >{item?.content || ''}</textarea
        >
      </div>

      <div class="rounded-2xl border bg-white p-6">
        <label class="block mb-2">Excerpt (Ringkasan)</label>
        <textarea id="excerpt" name="excerpt" rows="3" class="w-full rounded-xl border px-4 py-3"
          >{item?.excerpt || ''}</textarea
        >
      </div>
    </div>

    <div class="space-y-6">
      <div class="rounded-2xl border bg-white p-6">
        {
          item?.image && (
            <div class="mb-4">
              <label class="block mb-2 text-sm text-gray-500">Gambar Saat Ini</label>
              <img src={item.image} alt={item.title} class="w-full h-32 object-cover rounded-lg" />
            </div>
          )
        }
        <label class="block mb-2">Upload Gambar Baru (Opsional)</label>
        <input
          id="image"
          name="image"
          type="file"
          accept="image/*"
          class="w-full rounded-xl border px-4 py-3"
        />
        <div id="upload-status" class="text-sm mt-2 text-gray-500"></div>
      </div>

      <div class="rounded-2xl border bg-white p-6">
        <label class="block mb-2">Author</label>
        <input
          id="author"
          name="author"
          value={item?.author || 'Admin'}
          class="w-full rounded-xl border px-4 py-3"
        />
      </div>

      <div class="rounded-2xl border bg-white p-6">
        <label class="block mb-2">Status</label>
        <select id="is_active" name="is_active" class="w-full rounded-xl border px-4 py-3">
          <option value="true" selected={item?.is_active === true}>Aktif</option>
          <option value="false" selected={item?.is_active === false}>Nonaktif</option>
        </select>
      </div>

      <div class="flex gap-3">
        <a
          href="/admin/blog"
          class="w-full rounded-xl bg-gray-300 py-3 text-center text-gray-700 hover:bg-gray-400"
        >
          Batal
        </a>
        <button
          type="submit"
          class="w-full rounded-xl bg-blue-600 py-3 text-white hover:bg-blue-700"
        >
          Update
        </button>
      </div>
    </div>
  </form>
</AdminLayout>

<script is:inline>
  const form = document.querySelector('#edit-form');
  const statusDiv = document.querySelector('#upload-status');
  const currentUrl = window.location.pathname;
  const id = currentUrl.split('/').pop();

  form.addEventListener('submit', async function (e) {
    e.preventDefault();

    const title = document.querySelector('#title').value;
    const slug = document.querySelector('#slug').value;
    const content = document.querySelector('#content').value;
    const excerpt = document.querySelector('#excerpt').value || '';
    const author = document.querySelector('#author').value || 'Admin';
    const is_active = document.querySelector('#is_active').value === 'true';
    const fileInput = document.querySelector('#image');
    const file = fileInput?.files[0];

    if (!title || !slug || !content) {
      alert('Title, slug, dan konten wajib diisi');
      return;
    }

    let imageUrl = null;

    if (file) {
      statusDiv.textContent = 'Uploading gambar baru...';
      statusDiv.style.color = 'blue';

      try {
        const uploadFormData = new FormData();
        uploadFormData.append('image', file);

        const uploadRes = await fetch('/api/blog/upload', {
          method: 'POST',
          body: uploadFormData,
        });

        const uploadResult = await uploadRes.json();

        if (!uploadRes.ok) {
          throw new Error(uploadResult.error || 'Upload gagal');
        }

        imageUrl = uploadResult.url;
        statusDiv.textContent = 'Upload berhasil!';
        statusDiv.style.color = 'green';
      } catch (error) {
        statusDiv.textContent = 'Error: ' + error.message;
        statusDiv.style.color = 'red';
        alert('Gagal upload: ' + error.message);
        return;
      }
    }

    statusDiv.textContent = 'Menyimpan perubahan...';
    statusDiv.style.color = 'blue';

    try {
      const payload = {
        id: Number(id),
        title,
        slug,
        content,
        excerpt,
        author,
        is_active,
      };

      if (imageUrl) {
        payload.image = imageUrl;
      }

      const response = await fetch('/api/blog/update', {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload),
      });

      const result = await response.json();

      if (!response.ok) {
        throw new Error(result.error || 'Gagal update');
      }

      alert('Berhasil diupdate!');
      window.location.href = '/admin/blog';
    } catch (error) {
      console.error('Error:', error);
      statusDiv.textContent = 'Error: ' + error.message;
      statusDiv.style.color = 'red';
      alert('Gagal: ' + error.message);
    }
  });
</script>
