---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const blogs = [
  {
    id: 1,
    title: 'Pendaftaran KKA Tahun 2026',
    category: 'Informasi',
    status: 'Publish',
    author: 'Admin',
    created_at: '09 Juli 2026',
    thumbnail: 'https://placehold.co/120x80',
  },
  {
    id: 2,
    title: 'Pelaksanaan Tes Gelombang 1',
    category: 'Berita',
    status: 'Draft',
    author: 'Admin',
    created_at: '08 Juli 2026',
    thumbnail: 'https://placehold.co/120x80',
  },
];
---

<AdminLayout title="Blog">
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold">Blog</h1>

      <p class="mt-2 text-slate-500">Kelola seluruh artikel website.</p>
    </div>

    <a
      href="/admin/blog/create"
      class="rounded-xl bg-blue-600 px-5 py-3 text-white hover:bg-blue-700"
    >
      + Tambah Artikel
    </a>
  </div>

  <div class="mb-6 flex gap-4">
    <input
      type="text"
      placeholder="Cari artikel..."
      class="w-80 rounded-xl border border-slate-300 px-4 py-3"
    />

    <select class="rounded-xl border border-slate-300 px-4 py-3">
      <option>Semua Status</option>

      <option>Publish</option>

      <option>Draft</option>
    </select>
  </div>

  <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
    <table class="w-full">
      <thead class="bg-slate-50">
        <tr>
          <th class="p-4 text-left">Thumbnail</th>

          <th class="p-4 text-left">Judul</th>

          <th class="p-4 text-left">Kategori</th>

          <th class="p-4 text-left">Status</th>

          <th class="p-4 text-left">Penulis</th>

          <th class="p-4 text-left">Tanggal</th>

          <th class="p-4 text-center">Aksi</th>
        </tr>
      </thead>

      <tbody>
        {
          blogs.map((blog) => (
            <tr class="border-t">
              <td class="p-4">
                <img src={blog.thumbnail} class="h-16 w-24 rounded-lg object-cover" />
              </td>

              <td class="p-4">{blog.title}</td>

              <td class="p-4">{blog.category}</td>

              <td class="p-4">
                {blog.status === 'Publish' ? (
                  <span class="rounded-full bg-green-100 px-3 py-1 text-green-700">Publish</span>
                ) : (
                  <span class="rounded-full bg-yellow-100 px-3 py-1 text-yellow-700">Draft</span>
                )}
              </td>

              <td class="p-4">{blog.author}</td>

              <td class="p-4">{blog.created_at}</td>

              <td class="p-4">
                <div class="flex justify-center gap-3">
                  <a
                    href={`/admin/blog/edit/${blog.id}`}
                    class="rounded-lg bg-blue-600 px-4 py-2 text-white"
                  >
                    Edit
                  </a>

                  <button class="rounded-lg bg-red-600 px-4 py-2 text-white">Hapus</button>
                </div>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</AdminLayout>
