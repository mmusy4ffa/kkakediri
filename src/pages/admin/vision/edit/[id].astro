---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { supabaseServer } from '../../../../lib/supabaseServer';

export const prerender = false;

export async function getStaticPaths() {
  const { data: visions } = await supabaseServer.from('visions').select('id');

  return (
    visions?.map((vision) => ({
      params: { id: String(vision.id) },
    })) || []
  );
}

const { id } = Astro.params;

const { data: vision } = await supabaseServer
  .from('visions')
  .select('*')
  .eq('id', Number(id))
  .single();
---

<AdminLayout title="Edit Visi Misi">
  <div class="mb-8">
    <h1 class="text-3xl font-bold">Edit Visi Misi</h1>
  </div>

  <form id="edit-form" class="grid gap-8 lg:grid-cols-3">
    <div class="space-y-6 lg:col-span-2">
      <div class="rounded-2xl border bg-white p-6">
        <label class="block mb-2">Judul</label>
        <input
          id="title"
          name="title"
          value={vision?.title || ''}
          class="w-full rounded-xl border px-4 py-3"
        />
      </div>

      <div class="rounded-2xl border bg-white p-6">
        <label class="block mb-2">Deskripsi</label>
        <textarea
          id="description"
          name="description"
          rows="6"
          class="w-full rounded-xl border px-4 py-3">{vision?.description || ''}</textarea
        >
      </div>
    </div>

    <div class="space-y-6">
      <div class="rounded-2xl border bg-white p-6">
        <label class="block mb-2">Urutan</label>
        <input
          id="sort"
          name="sort_order"
          type="number"
          value={vision?.sort_order || 1}
          class="w-full rounded-xl border px-4 py-3"
        />
      </div>

      <div class="rounded-2xl border bg-white p-6">
        <label class="block mb-2">Status</label>
        <select id="is_active" name="is_active" class="w-full rounded-xl border px-4 py-3">
          <option value="true" selected={vision?.is_active === true}>Aktif</option>
          <option value="false" selected={vision?.is_active === false}>Nonaktif</option>
        </select>
      </div>

      <div class="flex gap-3">
        <a
          href="/admin/vision"
          class="w-full rounded-xl bg-gray-300 py-3 text-center text-gray-700 hover:bg-gray-400"
        >
          Batal
        </a>
        <button
          type="submit"
          class="w-full rounded-xl bg-blue-600 py-3 text-white hover:bg-blue-700"
        >
          Update
        </button>
      </div>
    </div>
  </form>
</AdminLayout>

<script is:inline>
  const form = document.querySelector('#edit-form');
  const statusDiv = document.createElement('div');
  statusDiv.className = 'text-sm mt-2';
  form?.appendChild(statusDiv);

  const currentUrl = window.location.pathname;
  const id = currentUrl.split('/').pop();

  form.addEventListener('submit', async function (e) {
    e.preventDefault();

    const title = document.querySelector('#title').value;
    const description = document.querySelector('#description').value;
    const sort_order = Number(document.querySelector('#sort').value);
    const is_active = document.querySelector('#is_active').value === 'true';

    if (!title || !description) {
      alert('Judul dan deskripsi wajib diisi');
      return;
    }

    statusDiv.textContent = 'Menyimpan...';
    statusDiv.style.color = 'blue';

    try {
      const response = await fetch('/api/vision/update', {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          id: Number(id),
          title: title,
          description: description,
          sort_order: sort_order || 1,
          is_active: is_active,
        }),
      });

      const result = await response.json();

      if (!response.ok) {
        throw new Error(result.error || 'Gagal update');
      }

      statusDiv.textContent = 'Berhasil diupdate!';
      statusDiv.style.color = 'green';

      setTimeout(function () {
        window.location.href = '/admin/vision';
      }, 1000);
    } catch (error) {
      console.error('Error:', error);
      statusDiv.textContent = 'Error: ' + error.message;
      statusDiv.style.color = 'red';
      alert('Gagal: ' + error.message);
    }
  });
</script>
