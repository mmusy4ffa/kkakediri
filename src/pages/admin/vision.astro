---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabaseServer } from '../../lib/supabaseServer';

export const prerender = false;

const { data: visions, error } = await supabaseServer
  .from('visions')
  .select('*')
  .order('sort_order', { ascending: true });
---

<AdminLayout title="Visi Misi">
  <div class="mb-8 flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold sm:text-3xl">Visi Misi</h1>
      <p class="mt-2 text-slate-500">Kelola visi dan misi website. Maksimal 2 data.</p>
    </div>

    <a
      href="/admin/vision/create"
      class="rounded-xl bg-blue-600 px-5 py-3 text-white hover:bg-blue-700"
    >
      Tambah Visi Misi
    </a>
  </div>

  <div class="overflow-hidden rounded-2xl border bg-white">
    <div class="overflow-x-auto">
      <table class="w-full min-w-[720px]">
        <thead class="bg-slate-50">
          <tr>
            <th class="p-4 text-left">Judul</th>
            <th class="p-4 text-left">Deskripsi</th>
            <th class="p-4 text-left">Urutan</th>
            <th class="p-4 text-left">Status</th>
            <th class="p-4 text-left">Aksi</th>
          </tr>
        </thead>
        <tbody>
          {
            visions?.map((vision) => (
              <tr class="border-t">
                <td class="p-4 font-semibold">{vision.title}</td>
                <td class="p-4 max-w-xs truncate">{vision.description}</td>
                <td class="p-4">{vision.sort_order}</td>
                <td class="p-4">
                  {vision.is_active ? (
                    <span class="rounded-full bg-green-100 px-3 py-1 text-green-700">Aktif</span>
                  ) : (
                    <span class="rounded-full bg-red-100 px-3 py-1 text-red-700">Nonaktif</span>
                  )}
                </td>
                <td class="p-4">
                  <div class="flex gap-3">
                    <a
                      href={`/admin/vision/edit/${vision.id}`}
                      class="rounded-lg bg-yellow-500 px-4 py-2 text-white hover:bg-yellow-600"
                    >
                      Edit
                    </a>
                    <button
                      data-id={vision.id}
                      data-title={vision.title}
                      class="delete-btn rounded-lg bg-red-600 px-4 py-2 text-white hover:bg-red-700"
                    >
                      Hapus
                    </button>
                  </div>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    {
      visions?.length === 0 && (
        <div class="p-8 text-center text-slate-500">Belum ada data visi misi.</div>
      )
    }
  </div>
</AdminLayout>

<script is:inline>
  document.querySelectorAll('.delete-btn').forEach(function (btn) {
    btn.addEventListener('click', async function () {
      const id = this.dataset.id;
      const title = this.dataset.title;

      if (!confirm('Yakin ingin menghapus "' + title + '"?')) {
        return;
      }

      try {
        const response = await fetch('/api/vision/delete', {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ id: Number(id) }),
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.error || 'Gagal menghapus');
        }

        alert('Berhasil dihapus!');
        location.reload();
      } catch (error) {
        console.error('Error:', error);
        alert('Gagal menghapus: ' + error.message);
      }
    });
  });
</script>
