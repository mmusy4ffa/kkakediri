---
// export const prerender = false;
const { title, subtitle, image, buttonText, buttonLink } = Astro.props;
---

<section class="relative min-h-[60vh] md:min-h-[70vh] lg:min-h-[80vh] flex items-center">
  <div class="absolute inset-0 z-0">
    <img src={image || '/images/hero-bg.jpg'} alt="Hero" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-black/50"></div>
  </div>

  <div class="container mx-auto px-4 md:px-6 relative z-10 text-white">
    <div class="max-w-2xl">
      <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-bold leading-tight">
        {title || 'Kompetisi Kompetensi Akademik (KKA) 2026'}
      </h1>
      <p class="mt-3 md:mt-4 text-sm sm:text-base md:text-lg lg:text-xl text-white/90">
        {subtitle || '"Challenge Your Brain, Test Your Skills"'}
      </p>
      {
        buttonText && buttonLink && (
          <a
            href={buttonLink}
            class="mt-4 md:mt-6 inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 sm:px-6 md:px-8 py-2 sm:py-3 rounded-xl transition text-sm sm:text-base"
          >
            {buttonText}
          </a>
        )
      }
    </div>
  </div>
</section>
