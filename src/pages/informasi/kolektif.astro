---
import Layout from '../../layouts/MainLayout.astro';
import { supabase } from '../../lib/supabase';

const { data: items } = await supabase
  .from('registrations')
  .select('*')
  .eq('is_active', true)
  .order('sort_order', { ascending: true });
---

<Layout title="Pendaftaran Kolektif">
  <section class="py-12 md:py-16">
    <div class="container mx-auto px-4 md:px-6 max-w-4xl">
      <div class="text-center mb-10 md:mb-16">
        <h1 class="text-3xl md:text-4xl font-bold">Pendaftaran Kolektif</h1>
        <p class="mt-2 text-slate-500">Pendaftaran melalui sekolah atau instansi</p>
      </div>

      {
        items?.map((item) => (
          <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-100 mb-8 last:mb-0">
            {item.image && (
              <img src={item.image} alt={item.title} class="w-full h-48 md:h-64 object-cover" />
            )}
            <div class="p-6 md:p-8 lg:p-10">
              <h2 class="text-2xl md:text-3xl font-bold mb-2">{item.title}</h2>
              {item.description && <p class="text-slate-500 mb-4">{item.description}</p>}
              <div class="text-slate-700 leading-relaxed whitespace-pre-wrap">{item.content}</div>
            </div>
          </div>
        ))
      }

      {
        items?.length === 0 && (
          <div class="text-center py-12">
            <p class="text-slate-500">Informasi pendaftaran kolektif belum tersedia.</p>
          </div>
        )
      }
    </div>
  </section>
</Layout>
