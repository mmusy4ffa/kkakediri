---
const programs = [
  {
    title: 'Pendaftaran Mandiri',
    description: 'Peserta melakukan pendaftaran secara individu melalui website.',
    icon: '👤',
    link: '/informasi/mandiri',
  },
  {
    title: 'Pendaftaran Kolektif',
    description: 'Pendaftaran dilakukan oleh sekolah, kampus, atau instansi.',
    icon: '👥',
    link: '/informasi/kolektif',
  },
  {
    title: 'Sertifikasi Kompetensi',
    description: 'Pelaksanaan uji kompetensi sesuai skema yang dipilih.',
    icon: '🏆',
    link: '/regulasi',
  },
];
---

<section class="py-24 bg-white">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center mb-16">
      <span class="text-blue-600 font-semibold"> PROGRAM </span>

      <h2 class="mt-3 text-5xl font-bold">Program KKA Radar</h2>

      <p class="mt-5 text-slate-500">Pilih layanan yang sesuai dengan kebutuhan Anda.</p>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      {
        programs.map((program) => (
          <div class="rounded-3xl border border-slate-200 bg-white p-8 transition hover:-translate-y-2 hover:shadow-xl">
            <div class="mb-6 text-5xl">{program.icon}</div>

            <h3 class="text-2xl font-bold">{program.title}</h3>

            <p class="mt-4 leading-8 text-slate-600">{program.description}</p>

            <a
              href={program.link}
              class="mt-8 inline-block font-semibold text-blue-600 hover:underline"
            >
              Selengkapnya →
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
