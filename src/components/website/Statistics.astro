---
const stats = [
  {
    number: '10.000+',
    title: 'Peserta',
  },
  {
    number: '120+',
    title: 'Mitra',
  },
  {
    number: '50+',
    title: 'Skema Sertifikasi',
  },
  {
    number: '15',
    title: 'Tahun Pengalaman',
  },
];
---

<section class="bg-blue-600 py-20">
  <div class="mx-auto grid max-w-7xl gap-10 px-6 text-center text-white md:grid-cols-4">
    {
      stats.map((stat) => (
        <div>
          <h2 class="text-5xl font-bold">{stat.number}</h2>

          <p class="mt-4 text-lg">{stat.title}</p>
        </div>
      ))
    }
  </div>
</section>
