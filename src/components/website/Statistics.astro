---
import { getStatistics } from '../../services/statistic';

const stats = await getStatistics();
const activeStats = stats
  .filter((item) => item.is_active)
  .sort((a, b) => a.sort_order - b.sort_order);
---

{
  activeStats.length > 0 && (
    <section class="py-12 md:py-16 bg-blue-600 text-white">
      <div class="container mx-auto px-4 md:px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 max-w-4xl mx-auto">
          {activeStats.map((item) => (
            <div class="text-center">
              <div class="text-3xl md:text-4xl lg:text-5xl font-bold">{item.value}</div>
              <div class="text-sm md:text-base mt-2 text-blue-100">{item.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
