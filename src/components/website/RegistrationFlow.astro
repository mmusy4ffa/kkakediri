---
const steps = [
  {
    number: '01',
    title: 'Pilih Program',
    description: 'Pilih program sertifikasi atau pelatihan yang ingin diikuti.',
  },
  {
    number: '02',
    title: 'Isi Formulir',
    description: 'Lengkapi formulir pendaftaran secara online.',
  },
  {
    number: '03',
    title: 'Verifikasi',
    description: 'Admin akan memverifikasi data dan dokumen peserta.',
  },
  {
    number: '04',
    title: 'Ikuti Pelatihan',
    description: 'Peserta mengikuti pelatihan dan uji kompetensi.',
  },
];
---

<section class="bg-slate-50 py-12 sm:py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <div class="mb-8 text-center sm:mb-12 md:mb-16">
      <span class="text-sm font-semibold text-blue-600 sm:text-base"> ALUR PENDAFTARAN </span>

      <h2 class="mt-2 text-2xl font-bold sm:mt-3 sm:text-3xl md:text-4xl lg:text-5xl">
        Langkah Mudah Mendaftar
      </h2>

      <p class="mt-3 text-sm text-slate-500 sm:mt-4 sm:text-base">
        Ikuti langkah berikut untuk menjadi peserta KKA Radar.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 sm:gap-6 md:grid-cols-4 md:gap-8">
      {
        steps.map((step) => (
          <div class="relative rounded-2xl bg-white p-5 shadow transition hover:-translate-y-2 sm:rounded-3xl sm:p-6 md:p-8">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-blue-600 text-lg font-bold text-white sm:mb-6 sm:h-16 sm:w-16 sm:text-2xl">
              {step.number}
            </div>

            <h3 class="text-lg font-bold sm:text-xl md:text-2xl">{step.title}</h3>

            <p class="mt-2 text-sm leading-relaxed text-slate-600 sm:mt-4 sm:text-base sm:leading-8">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
