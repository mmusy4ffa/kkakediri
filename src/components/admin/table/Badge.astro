---
interface Props {
  active: boolean;
}

const { active } = Astro.props;
---

{
  active ? (
    <span class="rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-700">
      Aktif
    </span>
  ) : (
    <span class="rounded-full bg-red-100 px-3 py-1 text-sm font-medium text-red-700">Nonaktif</span>
  )
}
