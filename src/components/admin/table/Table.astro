---
interface Props {
  headers: string[];
}

const { headers } = Astro.props;
---

<div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
  <table class="w-full">
    <thead class="bg-slate-50">
      <tr>
        {
          headers.map((header) => (
            <th class="border-b border-slate-200 p-5 text-left text-sm font-semibold text-slate-600">
              {header}
            </th>
          ))
        }
      </tr>
    </thead>

    <tbody>
      <slot />
    </tbody>
  </table>
</div>
