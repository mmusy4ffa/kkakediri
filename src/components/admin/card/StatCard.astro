---
interface Props {
  title: string;

  value: number;

  color?: string;
}

const { title, value, color = 'blue' } = Astro.props;
---

<div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <p class="text-slate-500">
    {title}
  </p>

  <h2 class="mt-4 text-5xl font-bold">
    {value}
  </h2>
</div>
