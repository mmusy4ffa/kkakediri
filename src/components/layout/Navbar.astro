---
const menus = [
  { title: 'Home', href: '/' },
  { title: 'Tentang KKA', href: '/tentang' },
  {
    title: 'Informasi',
    children: [
      {
        title: 'Pendaftaran Mandiri',
        href: '/informasi/mandiri',
      },
      {
        title: 'Pendaftaran Kolektif',
        href: '/informasi/kolektif',
      },
    ],
  },
  { title: 'Regulasi', href: '/regulasi' },
  { title: 'Galeri', href: '/galeri' },
  { title: 'Kontak', href: '/kontak' },
  { title: 'Blog', href: '/blog' },
];
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur-md">
  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6">
    <a href="/" class="flex items-center gap-3">
      <img src="/logo.png" class="h-12" />

      <div>
        <h1 class="font-bold text-xl text-slate-800">KKA RADAR</h1>

        <p class="text-xs text-slate-500">Kediri</p>
      </div>
    </a>

    <nav>
      <ul class="flex items-center gap-8">
        {
          menus.map((menu) =>
            menu.children ? (
              <li class="group relative">
                <button class="font-medium text-slate-700 hover:text-blue-600">{menu.title}</button>

                <div class="absolute left-0 top-full hidden w-64 rounded-xl border border-slate-200 bg-white p-2 shadow-xl group-hover:block">
                  {menu.children.map((child) => (
                    <a href={child.href} class="block rounded-lg px-4 py-3 hover:bg-slate-100">
                      {child.title}
                    </a>
                  ))}
                </div>
              </li>
            ) : (
              <li>
                <a href={menu.href} class="font-medium text-slate-700 hover:text-blue-600">
                  {menu.title}
                </a>
              </li>
            )
          )
        }
      </ul>
    </nav>
  </div>
</header>
