---
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width" />

    <title>{title}</title>
  </head>

  <body>
    <Navbar />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>
