---
import '../styles/global.css';
import Sidebar from '../components/admin/Sidebar.astro';
import Topbar from '../components/admin/Topbar.astro';

interface Props {
  title?: string;
}

const { title = 'Dashboard' } = Astro.props;
const session = Astro.cookies.get('admin_session')?.value;

if (session !== 'true') {
  return Astro.redirect('/admin/login');
}
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width" />

    <title>{title}</title>
  </head>

  <body class="bg-slate-100">
    <Sidebar />

    <div class="ml-72">
      <Topbar title={title} />

      <main class="p-8">
        <slot />
      </main>
    </div>
  </body>
</html>
